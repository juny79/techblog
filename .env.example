# ───────────────────────────────────────────────────
# LLM API Keys
# ───────────────────────────────────────────────────
OPENAI_API_KEY=sk-...
ANTHROPIC_API_KEY=sk-ant-...
DEFAULT_LLM=openai

# ───────────────────────────────────────────────────
# Tistory (Playwright 브라우저 자동화)
# Open API는 2024년 2월 종료 → 세션 파일 방식 사용
# 최초 1회: python scripts/setup_tistory_session.py
# ───────────────────────────────────────────────────
TISTORY_BLOG_NAME=your_blog_name          # xxx.tistory.com 에서 xxx
TISTORY_SESSION_FILE=storage/tistory_session.json

# ───────────────────────────────────────────────────
# Database (PostgreSQL)
# ───────────────────────────────────────────────────
DATABASE_URL=postgresql+asyncpg://techblog:password@localhost:5432/techblog

# ───────────────────────────────────────────────────
# Redis
# ───────────────────────────────────────────────────
REDIS_URL=redis://localhost:6379/0

# ───────────────────────────────────────────────────
# Google APIs (optional)
# ───────────────────────────────────────────────────
GOOGLE_ANALYTICS_PROPERTY_ID=
GOOGLE_SEARCH_CONSOLE_CREDENTIALS=

# ───────────────────────────────────────────────────
# Notifications (optional)
# ───────────────────────────────────────────────────
SLACK_WEBHOOK_URL=

# ───────────────────────────────────────────────────
# Blog Settings
# ───────────────────────────────────────────────────
POSTS_PER_DAY=2
MIN_WORD_COUNT=1500
TARGET_WORD_COUNT=2500
MAX_RETRY_COUNT=3
