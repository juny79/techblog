# ───────────────────────────────────────────────────
# LLM API Keys
# ───────────────────────────────────────────────────
OPENAI_API_KEY=sk-...
ANTHROPIC_API_KEY=sk-ant-...
DEFAULT_LLM=openai

# ───────────────────────────────────────────────────
# Tistory OAuth 2.0
# https://www.tistory.com/guide/api/manage/register
# ───────────────────────────────────────────────────
TISTORY_APP_ID=your_app_id
TISTORY_SECRET_KEY=your_secret_key
TISTORY_ACCESS_TOKEN=your_access_token
TISTORY_BLOG_NAME=your_blog_name
TISTORY_CALLBACK_URL=http://localhost:8000/callback

# ───────────────────────────────────────────────────
# Database (PostgreSQL)
# ───────────────────────────────────────────────────
DATABASE_URL=postgresql+asyncpg://techblog:password@localhost:5432/techblog

# ───────────────────────────────────────────────────
# Redis
# ───────────────────────────────────────────────────
REDIS_URL=redis://localhost:6379/0

# ───────────────────────────────────────────────────
# Google APIs (optional)
# ───────────────────────────────────────────────────
GOOGLE_ANALYTICS_PROPERTY_ID=
GOOGLE_SEARCH_CONSOLE_CREDENTIALS=

# ───────────────────────────────────────────────────
# Notifications (optional)
# ───────────────────────────────────────────────────
SLACK_WEBHOOK_URL=

# ───────────────────────────────────────────────────
# Blog Settings
# ───────────────────────────────────────────────────
POSTS_PER_DAY=2
MIN_WORD_COUNT=1500
TARGET_WORD_COUNT=2500
MAX_RETRY_COUNT=3
